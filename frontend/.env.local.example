# Frontend Environment Variables
# Copy to .env.local and fill in values

# Internal URL used by the Next.js server to reach the backend for API proxying.
# This is NOT exposed to the browser — use your platform's internal service URL
# (e.g. http://backend:8000 on App Platform) or http://localhost:8000 for local dev.
BACKEND_URL=

# Optional: override the public-facing API base for client-side fetch calls.
# Leave empty to use the built-in Next.js proxy (recommended).
NEXT_PUBLIC_API_BASE=
