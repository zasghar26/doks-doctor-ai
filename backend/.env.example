DO_OAUTH_CLIENT_ID=
DO_OAUTH_CLIENT_SECRET=
# Redirect URI registered in the DO OAuth app.
# When using the Next.js proxy this should be your frontend URL + /auth/callback
# (e.g. https://your-app-url/auth/callback), not the backend port directly.
DO_OAUTH_REDIRECT_URI=https://your-app-url/auth/callback
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7
MODEL_ACCESS_KEY=
AI_BASE_URL=https://inference.do-ai.run/v1
AI_MODEL=router:my-router
CORS_ORIGINS=https://your-app-url
FRONTEND_URL=https://your-app-url
LOG_LEVEL=INFO
ENVIRONMENT=development
